# Root gitignore for uxray monorepo

# Dependencies
node_modules/
.pnp
.pnp.*

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-actions-on-save.json

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.bak

# Testing
coverage/

# Build outputs
dist/
build/
out/
.next/
target/
